   :body "use crate::error::IoResultExt;\nuse crate::TempDir;\nuse std::io;\nuse std::path::PathBuf;\n\npub fn create(\n    path: PathBuf,\n    permissions: Option<&std::fs::Permissions>,\n    disable_cleanup: bool,\n) -> io::Result<TempDir> {\n    let mut dir_options = std::fs::DirBuilder::new();\n    #[cfg(not(target_os = \"wasi\"))]\n    {\n        use std::os::unix::fs::{DirBuilderExt, PermissionsExt};\n        if let Some(p) = permissions {\n            dir_options.mode(p.mode());\n        }\n    }\n    dir_options\n        .create(&path)\n        .with_err_path(|| &path)\n        .map(|_| TempDir {\n            path: path.into_boxed_path(),\n            disable_cleanup,\n        })\n}\n"} {:path "src/dir/imp/mod.rs"
   :sha256 "4df49b0c0e25a436ceaf566cfc0ca3da6793a91e6e29774d5628a482848f630c"
